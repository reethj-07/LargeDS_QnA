# Groq (fallback when Gemini errors or rate-limits): https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
# Optional Groq model overrides (defaults in src/config.py):
# MODEL_PLANNER=llama-3.1-8b-instant
# MODEL_ANALYST=llama-3.3-70b-versatile
# MODEL_CRITIC=llama-3.3-70b-versatile
# Batch answer-quality script forces 8B for analyst+critic unless you set:
# ANSWER_QUALITY_USE_70B=1
# (or run: python scripts/answer_quality.py --use-70b)

# Google Gemini (Google AI Studio — primary when set): https://aistudio.google.com/apikey
# Either name works; if both Gemini + Groq are set, Gemini is tried first and Groq runs on failure.
# GEMINI_API_KEY=your_gemini_key_here
# GOOGLE_API_KEY=your_gemini_key_here
# LLM_PRIMARY=auto
# auto = use Gemini when a Gemini key is set, else Groq only | groq = always Groq (ignore Gemini key)
# Model IDs must match ai.google.dev (gemini-1.5-* often returns 404 on current API):
# MODEL_GEMINI_PLANNER=gemini-2.5-flash
# MODEL_GEMINI_ANALYST=gemini-2.5-pro
# MODEL_GEMINI_CRITIC=gemini-2.5-flash
# Cheaper / if 2.5 unavailable: try gemini-2.5-flash-lite or gemini-flash-latest
# GEMINI_MAX_RETRIES=6
# Per-request retries inside ChatGoogleGenerativeAI (429 / quota / transient). Lower (e.g. 1–2) fails faster toward Groq fallback.
# GEMINI_INVOKE_RETRY_ATTEMPTS=3
# Full invoke-level retries with jitter after inner retries exhaust (batch jobs). Set 1 to disable outer layer.

# Optional: HuggingFace token (not required for public JSONL downloads)
# HF_TOKEN=

# Retrieval: cross-encoder rerank after RRF (CPU). Set 0 for faster runs / no extra HF download.
# USE_CROSS_ENCODER=1
# RERANK_POOL=40
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── LangSmith tracing (free tier at https://smith.langchain.com) ──
# Uncomment to enable automatic tracing of all LangChain/LangGraph calls:
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_your_key_here
# LANGCHAIN_PROJECT=bigdata-qna

# ── OpenTelemetry (optional deeper instrumentation) ──
# OTEL_ENABLED=true
# OTEL_EXPORTER=console
# OTEL_ENDPOINT=http://localhost:4317
